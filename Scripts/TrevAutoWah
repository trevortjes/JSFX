desc:TrevAutoWah

// CREATED UTILIZING AI!!!!
//-----------------------------------------
// User Controls
//-----------------------------------------
slider1:200<20,5000,1>Min Cutoff (Hz)
slider2:5000<500,20000,1>Max Cutoff (Hz)
slider3:0.7<0.1,10,0.01>Resonance (Q)
slider4:50<5,200,1>Envelope Attack (ms)
slider5:150<5,500,1>Envelope Release (ms)

//-----------------------------------------
// Internal variables
//-----------------------------------------
@init
x1 = x2 = 0;
y1 = y2 = 0;
env = 0;

//-----------------------------------------
// Envelope follower & filter coefficient calc
//-----------------------------------------
@slider
min_fc = slider1;
max_fc = slider2;
Q = slider3;

attack = exp(-1/(slider4*0.001*srate));
release = exp(-1/(slider5*0.001*srate));

//-----------------------------------------
// Audio Processing
//-----------------------------------------
@sample
in = spl0;

//-----------------------------------------
// Envelope follower (RMS-ish)
//-----------------------------------------
absin = abs(in);
(env < absin) ? (
    env = attack*env + (1-attack)*absin;  // attack
) : (
    env = release*env + (1-release)*absin; // release
);

//-----------------------------------------
// Map envelope → cutoff frequency
//-----------------------------------------
env_norm = min(max(env, 0), 1);    // clamp 0–1
cutoff = min_fc + (max_fc - min_fc) * env_norm;

//-----------------------------------------
// Compute biquad coefficients
//-----------------------------------------
omega = 2 * $pi * cutoff / srate;
sn = sin(omega);
cs = cos(omega);
alpha = sn / (2*Q);

// LPF coefficients
b0 = (1 - cs) * 0.5;
b1 = 1 - cs;
b2 = (1 - cs) * 0.5;
a0 = 1 + alpha;
a1 = -2 * cs;
a2 = 1 - alpha;

// normalize
b0 /= a0;
b1 /= a0;
b2 /= a0;
a1 /= a0;
a2 /= a0;

//-----------------------------------------
// Biquad filtering
//-----------------------------------------
out = b0*in + b1*x1 + b2*x2 - a1*y1 - a2*y2;

x2 = x1;
x1 = in;
y2 = y1;
y1 = out;

// Output stereo
spl0 = out;
spl1 = out;
